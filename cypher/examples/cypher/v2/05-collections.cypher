CREATE
  (`alice`:`IRI` {`referenceId`: "alice"}),
  (`bob`:`IRI` {`referenceId`: "bob"}),
  (`carol`:`IRI` {`referenceId`: "carol"}),
  (`dave`:`IRI` {`referenceId`: "dave"}),
  (`genid0`:`BNode` {`referenceId`: "_:genid0"}),
  (`genid1`:`BNode` {`referenceId`: "_:genid1"}),
  (`genid2`:`BNode` {`referenceId`: "_:genid2"}),
  (`genid3`:`BNode` {`referenceId`: "_:genid3"}),
  (`genid4`:`BNode` {`referenceId`: "_:genid4"}),
  (`genid5`:`BNode` {`referenceId`: "_:genid5"}),
  (`lit_1`:`Literal` {`datatype`: "xsd:string", `referenceId`: "lit_1", `value`: "RDF"}),
  (`lit_2`:`Literal` {`datatype`: "xsd:string", `referenceId`: "lit_2", `value`: "Cypher"}),
