  (`nil`:`IRI` {`referenceId`: "rdf:nil"}),
  (`paper1`:`IRI` {`referenceId`: "paper1"}),
  (`genid0`)-[`e1`:`rdf:first` {`asserted`: true}]->(`lit_1`),
  (`genid0`)-[`e2`:`rdf:rest` {`asserted`: true}]->(`genid1`),
